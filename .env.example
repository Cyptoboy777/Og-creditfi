# ─────────────────────────────────────────────────────────
# CreditFi · Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────

# Your deployer wallet private key (EVM compatible — with 0x prefix)
# Supported: MetaMask, Trust Wallet, Rabby, OKX Wallet
# Get testnet tokens: https://faucet.0g.ai/
PRIVATE_KEY=0xyour_evm_private_key_here

# 0G Network RPC URLs (pre-filled, no change needed)
OG_TESTNET_RPC=https://evmrpc-testnet.0g.ai
OG_MAINNET_RPC=https://evmrpc.0g.ai

# Deployed contract address (auto-filled after: npm run deploy:testnet)
CREDITFI_TESTNET_ADDRESS=
CREDITFI_MAINNET_ADDRESS=

# ─────────────────────────────────────────────────────────
# AI SCORER — Gemini API Key
# Get a free key at: https://aistudio.google.com/apikey
# Used by the AI Scorer tab for deep credit risk analysis
# ─────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza_your_gemini_api_key_here

# 0G Storage configuration (for credit history blobs)
OG_STORAGE_NODE=https://indexer-storage-testnet-standard.0g.ai
OG_PRIVATE_KEY=${PRIVATE_KEY}

# Optional: Block explorer API key (not required for 0G)
EXPLORER_API_KEY=no-key-needed

